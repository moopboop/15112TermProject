class PerlinNoise:
    def __init__(self, seed=None):
        self.p = list(range(256))
        random.seed(seed)
        random.shuffle(self.p)
        self.p += self.p  # Duplicate to avoid overflow

    def fade(self, t):
        # 6t^5 - 15t^4 + 10t^3
        return t * t * t * (t * (t * 6 - 15) + 10)

    def lerp(self, t, a, b):
        return a + t * (b - a)

    def grad(self, hash, x, y):
        # Convert low 4 bits of hash code into 8 gradient directions
        h = hash & 7
        u = x if h < 4 else y
        v = y if h < 4 else x
        return (u if (h & 1) == 0 else -u) + (v if (h & 2) == 0 else -v)

    def noise(self, x, y):
        # Find unit grid cell containing point
        X = int(math.floor(x)) & 255
        Y = int(math.floor(y)) & 255
        
        # Get relative xy coordinates of point within cell
        xf = x - math.floor(x)
        yf = y - math.floor(y)
        
        # Compute fade curves for each of x, y
        u = self.fade(xf)
        v = self.fade(yf)
        
        # Hash coordinates of the 4 corners
        p = self.p
        aa = p[p[X] + Y]
        ab = p[p[X] + Y + 1]
        ba = p[p[X + 1] + Y]
        bb = p[p[X + 1] + Y + 1]
        
        # Add blended results from 4 corners
        return self.lerp(v, self.lerp(u, self.grad(aa, xf, yf),
                                         self.grad(ba, xf - 1, yf)),
                             self.lerp(u, self.grad(ab, xf, yf - 1),
                                         self.grad(bb, xf - 1, yf - 1)))

# Example usage: Generate a 10x10 grid
perlin = PerlinNoise(seed=42)
grid = [[perlin.noise(x * 0.1, y * 0.1) for x in range(10)] for y in range(10)]